{
  "name": "poke-sleep",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "seed:pokemon": "node server/scripts/seed_pokemon.js",
    "seed:main-skills": "node server/scripts/seed_main_skills.js",
    "seed:dishes": "node server/scripts/seed_dishes.js",
    "backup": "node server/scripts/create_backup.js",
    "restore": "node server/scripts/restore_backup.js",
    "build:client": "npm run build --workspace client",
    "start:server": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
